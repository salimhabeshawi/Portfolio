---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import aboutSkills from "../data/about-skills.json";
import timeline from "../data/timeline.json";
import socialLinks from "../data/social-links.json";
import homePageScriptUrl from "../scripts/home-page.js?url";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

const blogPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const technologyLabelByKey = new Map(
  aboutSkills
    .filter((skill) => skill.key)
    .map((skill) => [skill.key, skill.label]),
);

const formatTechnologyLabel = (technologyKey: string) =>
  technologyLabelByKey.get(technologyKey) ??
  technologyKey
    .split(" ")
    .map((word: string) => {
      const lowerWord = word.toLowerCase();
      if (lowerWord === "api") {
        return "API";
      }
      if (lowerWord === "ai") {
        return "AI";
      }

      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join(" ");
---

<BaseLayout
  title="Salim Ahmed | Portfolio"
  description="Salim Ahmed's portfolio — practical desktop tools, projects, blog, timeline, and contact links."
>
  <div class="page-shell">
    <header class="site-header">
      <a class="brand" href="#home">Salim Ahmed</a>
      <nav class="main-nav" aria-label="Main navigation">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#timeline">Timeline</a>
        <a href="#blog">Blog</a>
        <a href="#connect">Connect</a>
      </nav>
      <button
        id="themeToggle"
        class="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        aria-pressed="false"
      ></button>
    </header>

    <main id="home">
      <section class="hero section-lined">
        <p class="eyebrow">Developer Portfolio</p>
        <h1>Hi, I'm Salim Ahmed,</h1>
        <p class="hero-subtitle">a no-coffee -- no-problem developer.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="mailto:salimhabeshawi@gmail.com">Hire Me</a>
          <a
            class="btn btn-outline resume-btn"
            href="/assets/resume/Salim_Ahmed_Resume.pdf"
            download="Salim_Ahmed_Resume.pdf"
            >
            <span class="material-symbols-outlined" aria-hidden="true">picture_as_pdf</span>
            Download Résumé</a
          >
        </div>
      </section>

      <section id="about" class="section-lined about-grid">
        <div class="about-content">
          <h2>About</h2>
          <p>
            I am a <span class="highlighted">Back-End Engineer</span> with a capability to build your
            Full-Stack app. I help businesses ship reliable systems fast, from
            <span class="highlighted">operations dashboards</span> to
            <span class="highlighted">internal platforms</span> your team can use every day.
          </p>
          <span class="skills-tags" aria-label="Technologies I use">
            {aboutSkills.map((skill) =>
              skill.key ? (
                <button class="skill-tag filter-tag project-filter-tag" type="button" data-tag={skill.key}
                  >{skill.label}</button
                >
              ) : (
                <span class="skill-tag">{skill.label}</span>
              )
            )}
          </span>
        </div>
        <ul class="stats-grid" aria-label="Profile stats">
          <li>
            <strong>2025</strong>
            <span>Started building publicly</span>
          </li>
          <li>
            <strong>2+</strong>
            <span>Refined projects and still adding ...</span>
          </li>
          <li>
            <strong>100%</strong>
            <span>No coffee workflow</span>
          </li>
        </ul>
      </section>

      <section id="projects" class="section-lined">
        <div class="section-head">
          <h2>Projects</h2>
          <a class="btn btn-outline" href="https://github.com/salimhabeshawi" target="_blank" rel="noopener"
            >More on GitHub</a
          >
        </div>

        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card">
              <img src={project.data.image} alt={project.data.imageAlt} />
              <div class="project-content">
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="project-tags" aria-label={`${project.data.title} technologies`}>
                  {project.data.technologies.map((technologyKey: string) => (
                    <button
                      class="skill-tag filter-tag project-skill-tag project-filter-tag"
                      type="button"
                      data-tag={technologyKey}
                    >
                      {formatTechnologyLabel(technologyKey)}
                    </button>
                  ))}
                </div>
                {project.data.links.length > 1 ? (
                  <div class="project-actions">
                    {project.data.links.map((link) => (
                      <a class="btn btn-primary" href={link.url} target="_blank" rel="noopener">{link.label}</a>
                    ))}
                  </div>
                ) : (
                  project.data.links.map((link) => (
                    <a class="btn btn-primary" href={link.url} target="_blank" rel="noopener">{link.label}</a>
                  ))
                )}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="timeline" class="section-lined">
        <h2>Timeline</h2>
        <div class="timeline-scroll-shell">
          <ol class="timeline-list">
            {timeline.map((entry) => (
              <li>
                <span class="year">{entry.year}</span>
                <div class="timeline-year-box">
                  <ul class="timeline-month-list">
                    {entry.months.map((monthEntry) => (
                      <li>
                        <strong class="timeline-month">{monthEntry.month}</strong>
                        <ul class="timeline-achievements">
                          {monthEntry.achievements.map((achievement) => (
                            <li set:html={achievement} />
                          ))}
                        </ul>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ))}
          </ol>
          <div class="timeline-scrollbar" aria-hidden="true">
            <div class="timeline-scrollbar-thumb"></div>
          </div>
        </div>
      </section>

      <section id="blog" class="section-lined">
        <div class="section-head">
          <h2>Blog</h2>
          <a class="btn btn-outline" href="/blog">View all posts</a>
        </div>

        <div class="blog-grid">
          {blogPosts.map((post) => (
            <article class="blog-card">
              <p class="blog-date">{post.data.publishedAt.toLocaleDateString("en-US", { dateStyle: "long" })}</p>
              <h3>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.excerpt}</p>
              {post.data.tags.length ? (
                <div class="blog-tags" aria-label={`${post.data.title} tags`}>
                  {post.data.tags.map((tag) => (
                    <button class="skill-tag filter-tag blog-filter-tag blog-skill-tag" type="button" data-tag={tag}
                      >{tag}</button
                    >
                  ))}
                </div>
              ) : null}
              <a class="btn btn-primary" href={`/blog/${post.slug}/`}>Read post</a>
            </article>
          ))}
        </div>
      </section>

      <section id="connect" class="section-lined">
        <h2>Connect</h2>
        <div class="social-links">
          {socialLinks.map((socialLink) => (
            <a
              href={socialLink.href}
              target={socialLink.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={socialLink.href.startsWith("mailto:") ? undefined : "noopener"}
              >{socialLink.label}</a
            >
          ))}
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>

  <button
    id="scrollTopAid"
    class="scroll-aid scroll-top-aid"
    type="button"
    aria-label="Scroll to top"
    title="Scroll to top"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="17 11 12 6 7 11"></polyline>
      <polyline points="17 18 12 13 7 18"></polyline>
    </svg>
  </button>

  <button
    id="scrollBottomAid"
    class="scroll-aid scroll-bottom-aid"
    type="button"
    aria-label="Scroll to bottom"
    title="Scroll to bottom"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="7 13 12 18 17 13"></polyline>
      <polyline points="7 6 12 11 17 6"></polyline>
    </svg>
  </button>

  <script type="module" src={homePageScriptUrl}></script>
</BaseLayout>
